{
  "rules": {
    "projects": {
      ".read": true,
      ".write": "auth != null"
    },
    "collaborators": {
      ".read": true,
      ".write": "auth != null && root.child('roles').child(auth.uid).val() === 'admin'"
    },
    "news": {
      ".read": true,
      ".write": "auth != null"
    },
    "comments": {
      ".read": true,
      ".write": true
    },
    "roles": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('roles').child(auth.uid).val() === 'admin'"
    },
    "requests": {
      ".read": "auth != null",
      ".write": true
    },
    "invitations": {
      ".read": "auth != null",
      ".write": "auth != null"
    }
  }
}