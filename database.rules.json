{
  "rules": {
    "projects": {
      ".read": true,
      ".write": "auth != null && (root.child('roles').child(auth.uid).val() === 'admin' || root.child('roles').child(auth.uid).val() === 'developer')"
    },
    "collaborators": {
      ".read": true,
      ".write": "auth != null && root.child('roles').child(auth.uid).val() === 'admin'"
    },
    "news": {
      ".read": true,
      ".write": "auth != null && (root.child('roles').child(auth.uid).val() === 'admin' || root.child('roles').child(auth.uid).val() === 'developer')"
    },
    "comments": {
      ".read": true,
      ".write": true
    },
    "roles": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('roles').child(auth.uid).val() === 'admin'"
    },
    "users": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && (auth.uid === $uid || root.child('roles').child(auth.uid).val() === 'admin')"
      }
    },
    "requests": {
      ".read": "auth != null",
      ".write": true
    },
    "invitations": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "likes": {
      ".read": true,
      ".write": "auth != null"
    }
  }
}